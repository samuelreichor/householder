# Session encryption key — 32+ random chars. Generate with: openssl rand -hex 32
NUXT_SESSION_PASSWORD=

# Google OAuth credentials from https://console.cloud.google.com/apis/credentials
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Comma-separated list of allowed Google email addresses for this household.
# Leave empty to allow anyone with a Google account (not recommended).
NUXT_ALLOWED_EMAILS=samuelreichor@gmail.com
